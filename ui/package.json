{
  "type": "module",
  "scripts": {
    "build-with-check": "run-p type-check \"build-only {@}\" --",
    "build": "rsbuild build",
    "dev": "rsbuild build --watch --env-mode=development",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path ../.gitignore",
    "lint:eslint": "eslint . --fix",
    "lint": "run-s lint:*",
    "prettier": "prettier --write src/",
    "test:unit": "vitest --passWithNoTests",
    "type-check": "vue-tsc --build"
  },
  "prettier": {
    "printWidth": 100,
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "plugins": [
      "prettier-plugin-organize-imports"
    ]
  },
  "dependencies": {
    "@halo-dev/api-client": "^2.24.0",
    "@halo-dev/components": "^2.24.0",
    "@halo-dev/ui-shared": "^2.24.0",
    "@tanstack/vue-query": "^4.44.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/router": "^14.3.0",
    "axios": "^1.16.1",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@halo-dev/ui-plugin-bundler-kit": "^2.24.0",
    "@iconify-json/ri": "^1.2.10",
    "@rsbuild/core": "^2.0.6",
    "@rsbuild/plugin-sass": "^1.5.2",
    "@tsconfig/node20": "^20.1.9",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.19.41",
    "@unocss/eslint-config": "^66.6.8",
    "@unocss/webpack": "^66.6.8",
    "@vitest/eslint-plugin": "^1.6.17",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-oxlint": "^0.16.12",
    "eslint-plugin-vue": "~10.0.1",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^7.0.2",
    "oxlint": "^0.16.12",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "sass": "^1.99.0",
    "typescript": "~5.8.3",
    "unocss": "^66.6.8",
    "unplugin-icons": "^23.0.1",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.9"
  },
  "packageManager": "pnpm@10.33.4"
}
