{
  "name": "@halo-dev/ai-foundation-sdk",
  "version": "0.1.0",
  "description": "Vue runtime helpers for Halo AI UI streams.",
  "keywords": [
    "halo",
    "ai",
    "vue",
    "chat",
    "streaming"
  ],
  "homepage": "https://github.com/halo-dev/plugin-ai-foundation#readme",
  "bugs": {
    "url": "https://github.com/halo-dev/plugin-ai-foundation/issues"
  },
  "license": "GPL-3.0",
  "author": {
    "name": "@halo-dev",
    "url": "https://github.com/halo-dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/halo-dev/plugin-ai-foundation.git",
    "directory": "ui/packages/sdk"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "rstest run --config rstest.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "vue": "^3.5.x"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rstest/core": "^0.10.0",
    "@vue/tsconfig": "^0.7.0",
    "typescript": "~5.8.3",
    "vue": "^3.5.34"
  },
  "packageManager": "pnpm@10.33.4"
}
